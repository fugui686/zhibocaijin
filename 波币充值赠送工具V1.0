        # 操作按钮框
        box2 = QFrame()
        box2.setStyleSheet("""
            QFrame {
                background: white;
                border: 1px solid #dcdfe6;
                border-radius: 8px;
            }
        """)
        box2_layout = QVBoxLayout(box2)
        box2_layout.setContentsMargins(15, 15, 15, 15)
        box2_layout.setSpacing(12)

        title2 = QLabel("执行操作")
        title2.setStyleSheet("font-size:20px;font-weight:bold; color:#303133;")

        # 操作按钮
        action_layout = QHBoxLayout()
        action_layout.setSpacing(15)

        self.btn_normal = QPushButton("平时模式")
        self.btn_holiday = QPushButton("节日模式")
        self.btn_export = QPushButton("📤 导出数据")

        for btn in [self.btn_normal, self.btn_holiday, self.btn_export]:
            btn.setFixedHeight(42)
            btn.setMinimumWidth(120)
            btn.setCursor(Qt.PointingHandCursor)

        # 设置操作按钮默认样式
        self.btn_normal.setStyleSheet(self.get_button_style(False, False))
        self.btn_holiday.setStyleSheet(self.get_button_style(False, False))
        self.btn_export.setStyleSheet(self.get_button_style(False, False))

        # 操作按钮点击事件
        self.btn_normal.clicked.connect(lambda: self.on_action_click(self.btn_normal, "normal"))
        self.btn_holiday.clicked.connect(lambda: self.on_action_click(self.btn_holiday, "holiday"))
        self.btn_export.clicked.connect(self.on_export_click)

        action_layout.addWidget(self.btn_normal)
        action_layout.addWidget(self.btn_holiday)
        action_layout.addWidget(self.btn_export)
        action_layout.addStretch()

        box2_layout.addWidget(title2)
        box2_layout.addLayout(action_layout)

        # 日志框
        log_box = QFrame()
        log_box.setStyleSheet("""
            QFrame {
                background: white;
                border: 1px solid #dcdfe6;
                border-radius: 8px;
            }
        """)
        log_layout = QVBoxLayout(log_box)
        log_layout.setContentsMargins(15, 15, 15, 15)
        log_layout.setSpacing(10)

        log_title = QLabel("运行日志")
        log_title.setStyleSheet("font-size:20px;font-weight:bold; color:#303133;")

        self.log_edit = QLineEdit()
        self.log_edit.setReadOnly(True)
        self.log_edit.setPlaceholderText("这里显示最新日志...")
        self.log_edit.setMinimumHeight(45)
        self.log_edit.setStyleSheet("""
            QLineEdit {
                border: 1px solid #dcdfe6;
                border-radius: 4px;
                padding: 8px 12px;
                background: #f5f7fa;
                font-size: 13px;
                color: #606266;
            }
        """)

        log_layout.addWidget(log_title)
        log_layout.addWidget(self.log_edit)

        # 添加到主布局
        layout.addWidget(box1)  # 日期范围框
        layout.addWidget(box2)  # 操作按钮框
        layout.addWidget(log_box, 0)  # 日志框不拉伸，自适应高度
        layout.addStretch(1)  # 添加弹性空间，占满剩余空间

        return page

    def build_config_page(self):
        page = QWidget()
        layout = QVBoxLayout(page)
        layout.setSpacing(12)
        layout.setContentsMargins(10, 10, 10, 10)  # 设置边距

        # 小组配置框 - 让它占据更多空间
        box1 = QFrame()
        box1.setStyleSheet(self.box_style())
        box1_layout = QVBoxLayout(box1)
        box1_layout.setContentsMargins(12, 12, 12, 12)

        title1 = QLabel("小组配置（勾选节日模式的小组按节日2~5%比例赠送, 不勾选按照平时1~3%比例赠送）")
        title1.setStyleSheet("font-size:20px;font-weight:bold;")

        self.group_scroll = QScrollArea()
        self.group_scroll.setWidgetResizable(True)
        self.group_scroll.setMinimumHeight(350)
        # 让滚动区域可以自动扩展
        self.group_scroll.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Expanding)

        self.group_container = QWidget()
        self.group_container_layout = QVBoxLayout(self.group_container)
        self.group_container_layout.setSpacing(8)
        self.group_container_layout.addStretch()

        self.group_scroll.setWidget(self.group_container)

        box1_layout.addWidget(title1)
        box1_layout.addWidget(self.group_scroll, 1)  # 1 表示让它占据多余空间

        # 通用配置框 - 添加弹性空间让它下移
        box2 = QFrame()
        box2.setStyleSheet(self.box_style())
        box2_layout = QVBoxLayout(box2)
        box2_layout.setContentsMargins(12, 12, 12, 12)

        title2 = QLabel("通用配置")
        title2.setStyleSheet("font-size:16px;font-weight:bold;")

        # 通用配置内容
        row = QHBoxLayout()
        self.port_input = QLineEdit()
        self.port_input.setPlaceholderText("端口号")

        self.code_input = QLineEdit()
        self.code_input.setPlaceholderText("小明计算器登录码")

        row.addWidget(QLabel("端口号："))
        row.addWidget(self.port_input)
        row.addSpacing(20)
        row.addWidget(QLabel("登录码："))
        row.addWidget(self.code_input)

        box2_layout.addWidget(title2)
        box2_layout.addLayout(row)

        self.btn_save_config = QPushButton("保存配置")
        self.btn_save_config.setFixedHeight(42)
        self.btn_save_config.setStyleSheet(self.get_button_style(False, False))
        self.btn_save_config.clicked.connect(self.save_config_from_ui)

        # 修改这里的布局
        layout.addWidget(box1, 5)  # 小组配置框占 5 份（增大占比）
        layout.addStretch(0)  # 去掉中间的弹性空间，或者设为很小的值
        layout.addWidget(box2, 1)  # 通用配置框占 1 份
        layout.addWidget(self.btn_save_config, 0)
        layout.addStretch(0)

        return page

    def box_style(self):
        return """
            QFrame {
                background: white;
                border: 1px solid #dcdfe6;
                border-radius: 8px;
            }
            QLabel {
                font-size: 13px;
            }
            QLineEdit, QDateEdit {
                border: 1px solid #c0c4cc;
                border-radius: 4px;
                padding: 8px;
                min-height: 20px;
            }
            QPushButton {
                background: #409eff;
                color: white;
                border: none;
                border-radius: 6px;
                padding: 10px 16px;
                min-width: 80px;
            }
            QPushButton:hover {
                background: #66b1ff;
            }
            QScrollArea {
                border: none;
                background: transparent;
            }
        """

    def on_date_click(self, button, date_type):
        """处理日期按钮点击"""
        # 重置所有日期按钮为默认样式
        self.btn_prev_day.setStyleSheet(self.get_button_style(False, True))
        self.btn_today.setStyleSheet(self.get_button_style(False, True))
        self.btn_next_day.setStyleSheet(self.get_button_style(False, True))

        # 设置当前按钮为选中样式
        button.setStyleSheet(self.get_button_style(True, True))

        # 执行对应的日期切换功能
        if date_type == "prev":
            self.set_prev_day()
        elif date_type == "today":
            self.set_today()
        elif date_type == "next":
            self.set_next_day()

    def on_action_click(self, button, mode):
        """处理操作按钮点击"""
        # 重置所有操作按钮为默认样式
        self.btn_normal.setStyleSheet(self.get_button_style(False, False))
        self.btn_holiday.setStyleSheet(self.get_button_style(False, False))
        self.btn_export.setStyleSheet(self.get_button_style(False, False))

        # 设置当前按钮为选中样式
        button.setStyleSheet(self.get_button_style(True, False))

        # 执行任务
        self.start_task(mode)

    def on_export_click(self):
        """处理导出按钮点击"""
        # 重置所有操作按钮为默认样式
        self.btn_normal.setStyleSheet(self.get_button_style(False, False))
        self.btn_holiday.setStyleSheet(self.get_button_style(False, False))
        self.btn_export.setStyleSheet(self.get_button_style(False, False))

        # 设置导出按钮为选中样式
        self.btn_export.setStyleSheet(self.get_button_style(True, False))

        # 执行导出功能
        self.export_files()

    def clear_group_rows(self):
        for row in self.小组行列表:
            row.setParent(None)
            row.deleteLater()
        self.小组行列表.clear()

    def add_group_row(self, group_name="", cookie="", payment_class_id="", holiday_mode=False):
        """添加小组配置行，支持节日模式参数"""
        row = 小组配置行(group_name, cookie, payment_class_id, holiday_mode)
        row.删除按钮.clicked.connect(lambda: self.remove_group_row(row))
        self.group_container_layout.insertWidget(self.group_container_layout.count() - 1, row)
        self.小组行列表.append(row)

    def remove_group_row(self, row):
        if row in self.小组行列表:
            self.小组行列表.remove(row)
        row.setParent(None)
        row.deleteLater()

    def load_config_to_ui(self):
        cfg = 读取配置()

        self.port_input.setText(cfg.get("SETTINGS", "port", fallback="").strip())
        self.code_input.setText(cfg.get("SETTINGS", "code", fallback="").strip())

        self.clear_group_rows()

        groups = 获取所有小组配置(cfg)
        if not groups:
            self.add_group_row("lvcha", "", "19054", False)
        else:
            for item in groups:
                self.add_group_row(
                    item.get("group_name", ""),
                    item.get("cookie", ""),
                    item.get("payment_class_id", ""),
                    item.get("holiday_mode", False)  # 传入节日模式状态
                )

    def collect_group_rows(self):
        """收集所有小组的配置，包括节日模式状态"""
        groups = []
        for row in self.小组行列表:
            group_name = row.小组输入.text().strip()
            cookie = row.cookie输入.text().strip()
            payment_class_id = row.支付ID输入.text().strip()
            holiday_mode = row.holiday_check.isChecked()  # 获取复选框状态

            if not group_name and not cookie and not payment_class_id:
                continue

            groups.append({
                "group_name": group_name,
                "cookie": cookie,
                "payment_class_id": payment_class_id,
                "holiday_mode": holiday_mode  # 添加节日模式状态
            })
        return groups

    def save_config_from_ui(self):
        port = self.port_input.text().strip()
        code = self.code_input.text().strip()
        groups = self.collect_group_rows()

        if not port:
            QMessageBox.warning(self, "提示", "端口不能为空")
            return
        if not code:
            QMessageBox.warning(self, "提示", "code 不能为空")
            return
        if not groups:
            QMessageBox.warning(self, "提示", "请至少配置一个小组")
            return

        group_names = []
        for g in groups:
            if not g["group_name"]:
                QMessageBox.warning(self, "提示", "存在小组名为空，请检查")
                return
            if not g["cookie"]:
                QMessageBox.warning(self, "提示", f"小组 {g['group_name']} 的 cookie 不能为空")
                return
            if not g["payment_class_id"]:
                QMessageBox.warning(self, "提示", f"小组 {g['group_name']} 的波币支付ID 不能为空")
                return
            group_names.append(g["group_name"])

        if len(group_names) != len(set(group_names)):
            QMessageBox.warning(self, "提示", "小组名不能重复")
            return

        保存配置文件(
            通用配置={"port": port, "code": code},
            小组配置列表=groups
        )
        QMessageBox.information(self, "提示", "配置保存成功")

    def set_prev_day(self):
        current_date = self.begin_date.date()
        prev_date = current_date.addDays(-1)
        self.begin_date.setDate(prev_date)
        self.end_date.setDate(prev_date)

    def set_today(self):
        d = QDate.currentDate()
        self.begin_date.setDate(d)
        self.end_date.setDate(d)

    def set_next_day(self):
        current_date = self.begin_date.date()
        next_date = current_date.addDays(1)
        self.begin_date.setDate(next_date)
        self.end_date.setDate(next_date)

    def append_log(self, text):
        self.log_edit.setText(text)

    def set_buttons_enabled(self, enabled: bool):
        self.btn_normal.setEnabled(enabled)
        self.btn_holiday.setEnabled(enabled)
        self.btn_export.setEnabled(enabled)
        self.btn_save_config.setEnabled(enabled)

    def start_task(self, mode):
        cfg = 读取配置()
        port = cfg.get("SETTINGS", "port", fallback="").strip()
        code = cfg.get("SETTINGS", "code", fallback="").strip()
        groups = 获取所有小组配置(cfg)

        if not port:
            QMessageBox.warning(self, "提示", "请先在配置页填写端口")
            return
        if not code:
            QMessageBox.warning(self, "提示", "请先在配置页填写 code")
            return
        if not groups:
            QMessageBox.warning(self, "提示", "请先在配置页配置小组")
            return

        begin_py = self.begin_date.date().toPyDate()
        end_py = self.end_date.date().toPyDate()

        if begin_py > end_py:
            QMessageBox.warning(self, "提示", "开始日期不能大于结束日期")
            return

        self.set_buttons_enabled(False)
        self.append_log("任务开始执行...")

        self.thread = QThread()
        self.worker = Worker(
            port=port,
            code=code,
            groups=groups,
            开始日期=begin_py,
            结束日期=end_py,
            模式=mode
        )
        self.worker.moveToThread(self.thread)

        self.thread.started.connect(self.worker.run)
        self.worker.log.connect(self.append_log)
        self.worker.finished.connect(self.on_task_finished)
        self.worker.error.connect(self.on_task_error)

        self.worker.finished.connect(self.thread.quit)
        self.worker.error.connect(self.thread.quit)
        self.thread.finished.connect(self.thread.deleteLater)

        self.thread.start()

    def on_task_finished(self, result):
        self.set_buttons_enabled(True)
        self.latest_detail_file = result.get("明细文件", "")
        self.latest_bonus_file = result.get("赠送文件", "")
        count = result.get("赠送条数", 0)
        失败小组 = result.get("失败小组", [])

        self.append_log("任务完成")

        提示信息 = f"任务完成\n\n已生成文件：\n{os.path.basename(self.latest_detail_file)}\n{os.path.basename(self.latest_bonus_file)}\n\n赠送记录条数：{count}"

        if 失败小组:
            提示信息 += f"\n\n以下小组处理失败:\n{', '.join(失败小组)}"

        QMessageBox.information(self, "提示", 提示信息)

    def on_task_error(self, err_text):
        self.set_buttons_enabled(True)
        self.append_log("任务执行失败")
        QMessageBox.critical(self, "错误", err_text)

    def export_files(self):
        if not self.latest_detail_file or not os.path.exists(self.latest_detail_file):
            QMessageBox.warning(self, "提示", "还没有生成明细文件，请先点击平时或节日按钮")
            return
        if not self.latest_bonus_file or not os.path.exists(self.latest_bonus_file):
            QMessageBox.warning(self, "提示", "还没有生成赠送文件，请先点击平时或节日按钮")
            return

        QMessageBox.information(self, "提示", "已尝试打开刚生成的两份 Excel 文件")
        打开文件(self.latest_detail_file)
        打开文件(self.latest_bonus_file)


if __name__ == "__main__":
    创建默认配置()
    app = QApplication(sys.argv)
    win = MainWindow()
    win.show()
    sys.exit(app.exec_())
