STAGGER_MAX_MS = 5000  # 每个小组启动错峰 0~5000ms


class WorkerSignals(QObject):  # 定义信号类，用于线程与主线程通信
    finished = pyqtSignal(str, str)  # (group_name, message)
    data_ready = pyqtSignal(str, list, dict, dict)  # (group_name, game_ids, user_bets_dict, app_id_map)
    progress = pyqtSignal(str, int)  # (group_name, percent)
    status = pyqtSignal(str)  # 状态栏文本更新信号
    raw_count = pyqtSignal(str, int)  # 原始条数（未去重），(group_name, raw_total)
    appid_progress = pyqtSignal(str, int, int)  # (group_name, current, total) appid获取进度


class DataWorker(QRunnable):  # 数据处理线程
    def __init__(self, signals, port, token, code, start_time, end_time, group_name=""):
        super().__init__()
        self.signals = signals
        self.port = port
        self.code = code
        self.token = token
        self.start_time = start_time
        self.end_time = end_time
        self.group_name = group_name  # 小组名称
        self.game_ids = []  # 去重后的游戏ID
        self.is_running = True  # 控制线程是否继续运行
        self.mutex = QMutex()  # 保护标志位的互斥锁
        self.raw_total = 0  # 原始条数（未去重）
        # 存储每个用户的总有效投注
        self.user_bets = {}  # {user_id: 累计有效投注}
        # 新增：存储game_id到app_id的映射
        self.app_id_map = {}  # {game_id: app_id}

    def get_app_ids_for_users(self, game_ids, headers, port, code):
        """高并发批量获取game_id对应的app_id - 使用100个线程"""
        app_id_map = {}
        url = f'http://lvcha.boinht.com:{port}/user/pf_list_with_game'

        total = len(game_ids)
        completed = 0
        lock = threading.Lock()  # 需要导入threading

        def fetch_single_app_id(game_id):
            """单个game_id的获取函数"""
            nonlocal completed

            data = {
                'channel_id': '',
                'open_channel_id': '',
                'id': '',
                'game_user_id': game_id,
                'is_bind': '',
                'is_black': '',
                'nickname': '',
                'is_online': '',
                'reg_ip': '',
                'is_recharge': '',
                'device_type': '',
                'mobile': '',
                'apns_code': '',
                'begin_time': '',
                'end_time': '',
                'page_size': '32',
                'page': '1',
                'login_code': code,
            }

            # 重试机制
            MAX_RETRIES = 2
            retry_count = 0
            while retry_count < MAX_RETRIES:
                try:
                    response = requests.post(url, headers=headers, data=data, timeout=10)
                    if response.status_code == 200:
                        result = response.json().get('result', [])
                        if result and len(result) > 0:
                            app_id = result[0].get('app_user_id')
                            if app_id:
                                with lock:
                                    app_id_map[game_id] = app_id
                            break
                    else:
                        retry_count += 1
                except Exception as e:
                    retry_count += 1
                    if retry_count < MAX_RETRIES:
                        time.sleep(0.5)

            # 更新进度
            with lock:
                completed += 1
                if completed % 50 == 0 or completed == total:  # 每50个或最后一个更新进度
                    self.signals.appid_progress.emit(self.group_name, completed, total)

        # 使用线程池，固定100个线程
        with ThreadPoolExecutor(max_workers=100) as executor:
            # 提交所有任务
            futures = [executor.submit(fetch_single_app_id, game_id) for game_id in game_ids]

            # 等待所有任务完成（进度已经在fetch_single_app_id中更新）
            for future in as_completed(futures):
                if not self.is_running:
                    # 如果线程被要求停止，取消所有未完成的任务
                    executor.shutdown(wait=False, cancel_futures=True)
                    break

        return app_id_map

    def run(self):
        try:
            print(f"🟢 正在获取 [{self.group_name}] 游戏总人数及有效投注")
            headers = {
                'Cookie': f'token={self.token}',
            }

            url = f"http://v.boinht.com:{self.port}/pp_game_log/pf_list"

            游戏id_set = set()
            progress = 0
            page = 1
            self.signals.status.emit(f"[{self.group_name}] 正在获取数据...")
            self.signals.progress.emit(self.group_name, 0)

            while True:
                self.mutex.lock()
                if not self.is_running:
                    self.mutex.unlock()
                    return
                self.mutex.unlock()

                print(f"[{self.group_name}] 请求第 {page} 页，每页5~6万条数据...")
                self.signals.status.emit(f"[{self.group_name}] 正在请求第 {page} 页...")

                data = {
                    "channel_id": "",
                    "open_channel_id": "",
                    "pid": "",
                    "game_type": "",
                    "user_id": "",
                    "transfer_id": "",
                    "begin_time": self.start_time,
                    "end_time": self.end_time,
                    "page_size": 60000,
                    "page": page,
                    "channel_i": "",
                    "channel_ii": "",
                    "login_code": self.code,
                }

                # 带间隔的通用重试机制
                MAX_RETRIES = 3
                retry_count = 0
                while retry_count < MAX_RETRIES:
                    try:
                        response = requests.post(url, data=data, headers=headers, timeout=30)
                        if response.status_code == 502:
                            raise requests.exceptions.HTTPError("502 Bad Gateway")
                        response.raise_for_status()
                        result = response.json().get('result', [])
                        break  # 成功
                    except requests.exceptions.RequestException as e:
                        retry_count += 1
                        print(f"[{self.group_name}] 请求失败（第 {retry_count} 次）：{e}")
                        self.signals.status.emit(
                            f"[{self.group_name}] 请求失败（第 {retry_count} 次），随机延迟10~15s 后重试..."
                        )
                        time.sleep(random.randint(10, 15))  # 每次失败后随机等待 10~15 秒

                else:
                    # 三次都失败
                    self.signals.status.emit(f"[{self.group_name}] 多次请求失败，跳过该小组")
                    self.signals.progress.emit(self.group_name, 0)
                    self.signals.finished.emit(self.group_name, f"[{self.group_name}] 请求失败：网络异常")
                    return

                if not result:
                    print(f"[{self.group_name}] 第 {page} 页为空，结束分页请求。")
                    break

                # 统计原始条数（未去重）
                self.raw_total += len(result)

                for aa in result:
                    self.mutex.lock()
                    if not self.is_running:
                        self.mutex.unlock()
                        return
                    self.mutex.unlock()

                    游戏id = aa.get('user_id')
                    if 游戏id:
                        游戏id_set.add(游戏id)

                        # 累加该用户的有效投注
                        bet = aa.get('available_bet', 0)
                        # 确保bet是数字，处理None或空值
                        if bet is None:
                            bet = 0
                        try:
                            bet = float(bet)  # 转换为浮点数，防止字符串等情况
                        except (ValueError, TypeError):
                            bet = 0

                        # 累加到该用户的总投注
                        self.user_bets[游戏id] = self.user_bets.get(游戏id, 0) + bet

                if page % 2 == 0:
                    pause_time = random.randint(3, 8)
                    time.sleep(pause_time)

                page += 1
                progress = min(95, progress + random.randint(3, 7))
                self.signals.progress.emit(self.group_name, progress)

            self.game_ids = list(游戏id_set)

            # 发出原始条数（未去重）
            self.signals.raw_count.emit(self.group_name, self.raw_total)

            # ✅ 新增：获取所有game_id对应的app_id
            if self.game_ids:
                self.signals.status.emit(f"[{self.group_name}] 正在获取 {len(self.game_ids)} 个用户的app_id...")
                self.app_id_map = self.get_app_ids_for_users(self.game_ids, headers, self.port, self.code)
                self.signals.status.emit(f"[{self.group_name}] app_id获取完成，成功获取 {len(self.app_id_map)} 个")
            else:
                self.app_id_map = {}

            # 完成状态信息（带去重、原始条数和有效投注）
            total_bet = sum(self.user_bets.values())  # 计算该组总有效投注
            self.signals.status.emit(
                f"[{self.group_name}] 数据获取完成：游戏总人数 {len(self.game_ids)}， "
                f"{self.raw_total} 条游戏数据，总有效投注 {total_bet:.2f}，"
                f"获取app_id {len(self.app_id_map)} 个"
            )
            self.signals.progress.emit(self.group_name, 100)

            # 发送数据时带上app_id_map
            self.signals.data_ready.emit(self.group_name, self.game_ids, self.user_bets, self.app_id_map)
            self.signals.finished.emit(self.group_name, f"[{self.group_name}] 所有数据已获取完成！")

            print(f"✅ 小组 [{self.group_name}] 任务完成：游戏总人数 {len(self.game_ids)} 个， "
                  f"{self.raw_total} 条游戏数据，总有效投注 {total_bet:.2f}，"
                  f"获取app_id {len(self.app_id_map)} 个")

        except Exception as e:
            self.signals.status.emit(f"[{self.group_name}] 发生异常")
            self.signals.progress.emit(self.group_name, 0)
            self.signals.finished.emit(self.group_name, f"[{self.group_name}] 错误: {e}")


