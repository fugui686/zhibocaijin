    def set_default_dates(self):
        today = QDate.currentDate()
        self.start_time_input.setDateTime(QDateTime(today, QTime(0, 0, 0)))
        self.end_time_input.setDateTime(QDateTime(today, QTime(23, 59, 59)))

    def move_to_previous_day(self):
        date = self.start_time_input.dateTime().addDays(-1).date()
        self.start_time_input.setDateTime(QDateTime(date, QTime(0, 0, 0)))
        self.end_time_input.setDateTime(QDateTime(date, QTime(23, 59, 59)))

    def move_to_next_day(self):
        date = self.start_time_input.dateTime().addDays(1).date()
        self.start_time_input.setDateTime(QDateTime(date, QTime(0, 0, 0)))
        self.end_time_input.setDateTime(QDateTime(date, QTime(23, 59, 59)))

    def start_processing(self):
        self.group_game_ids = {}
        self.group_user_bets = {}
        self.group_app_id_maps = {}
        self.group_raw_counts = {}
        self.workers = []

        port = self.port_input.text().strip()
        code = self.code_input.text().strip()

        missing_fields = []
        if not port:
            missing_fields.append("端口（port）")
        if not code:
            missing_fields.append("验证码（code）")
        if missing_fields:
            QMessageBox.warning(self, "输入错误", "请填写以下内容：\n" + "\n".join(missing_fields))
            return

        if self.end_time_input.dateTime() < self.start_time_input.dateTime():
            QMessageBox.warning(self, '警告', '结束时间不能早于开始时间')
            return

        start = self.start_time_input.dateTime().toString("yyyy-MM-dd HH:mm:ss")
        end = self.end_time_input.dateTime().toString("yyyy-MM-dd HH:mm:ss")
        self.start_datetime = datetime.strptime(start, '%Y-%m-%d %H:%M:%S')
        self.end_datetime = datetime.strptime(end, '%Y-%m-%d %H:%M:%S')

        start_time = int(self.start_datetime.timestamp())
        end_time = int(self.end_datetime.timestamp())

        groups_to_run = []
        skipped = []
        for g in list(self.token_inputs.keys()):
            token = self.token_inputs[g].text().strip()
            if token:
                groups_to_run.append(g)
            else:
                skipped.append(g)

        if not groups_to_run:
            QMessageBox.warning(self, "警告", "没有任何小组填写 Cookie，无法开始！")
            return

        if skipped:
            print("⚠️ 以下小组未填写 Cookie，已跳过：", "、".join(skipped))

        self.thread_pool.setMaxThreadCount(len(groups_to_run))

        self.total_groups = len(groups_to_run)
        self.completed_groups = 0

        self.status_label.setText(f"状态：准备开始…（共 {self.total_groups} 个小组，同时并发）")
        self.progress_bar.setVisible(True)
        self.progress_bar.setValue(0)

        self.disable_ui()

        for group in groups_to_run:
            delay = random.randint(0, STAGGER_MAX_MS)
            print(f"🚀 准备启动小组 [{group}]，错峰延迟 {delay}ms")
            QTimer.singleShot(delay, lambda g=group: self._start_worker(g, port, code, start_time, end_time))

    def _start_worker(self, group, port, code, start_time, end_time):
        token = self.token_inputs[group].text().strip()
        if not token:
            print(f"⚠️ 小组 [{group}] 启动时发现 Cookie 为空，跳过")
            self._mark_group_done(group, f"[{group}] Cookie 为空，已跳过")
            return

        self.current_group = group
        self.status_label.setText(f"正在处理小组：{group}")

        signals = WorkerSignals()
        worker = DataWorker(signals, port, token, code, start_time, end_time, group_name=group)
        self.workers.append(worker)

        signals.finished.connect(self.on_task_finished)
        signals.data_ready.connect(self.on_data_ready)
        signals.progress.connect(self.update_progress)
        signals.status.connect(self.update_status)
        signals.raw_count.connect(self.on_raw_count)
        signals.appid_progress.connect(self.on_appid_progress)

        self.thread_pool.start(worker)
        print(f"🧵 已启动任务：[{group}]")

    def on_appid_progress(self, group_name, current, total):
        percent = int((current / total) * 100)
        self.status_label.setText(f"状态：[{group_name}] 正在获取app_id {current}/{total} ({percent}%)")

    def on_raw_count(self, group_name: str, raw_count: int):
        self.group_raw_counts[group_name] = raw_count

    def update_status(self, message):
        self.status_label.setText(f"状态：{message}")

    def update_progress(self, group_name, value):
        if value < 100:
            self.status_label.setText(f"状态：[{group_name}] 进度 {value}% ...")
        else:
            self.status_label.setText(f"状态：[{group_name}] 进度 100% ✅")

    def on_data_ready(self, group_name, game_ids, user_bets, app_id_map):
        self.group_game_ids[group_name] = game_ids
        self.group_user_bets[group_name] = user_bets
        self.group_app_id_maps[group_name] = app_id_map
        print(f"📦 已保存 [{group_name}] 的游戏总人数 {len(game_ids)} 个，投注数据已保存，app_id {len(app_id_map)} 个")

    def _mark_group_done(self, group_name, message):
        # 统一完成逻辑（用于跳过/异常也能计入总体完成）
        self.completed_groups += 1
        if self.total_groups > 0:
            percent = int((self.completed_groups / self.total_groups) * 100)
            self.progress_bar.setValue(max(0, min(100, percent)))

        self.status_label.setText(f"状态：{message}（完成 {self.completed_groups}/{self.total_groups}）")

        if self.completed_groups >= self.total_groups:
            print("📦 所有小组数据已处理完毕！")

            # ✅ 修改为置顶弹窗
            msg_box = QMessageBox(self)
            msg_box.setWindowTitle("完成")
            msg_box.setText("所有小组数据已处理完毕！")
            msg_box.setIcon(QMessageBox.Information)
            msg_box.setWindowFlags(msg_box.windowFlags() | Qt.WindowStaysOnTopHint)
            msg_box.exec_()

            self.enable_ui()
            QTimer.singleShot(500, lambda: self.progress_bar.setVisible(False))

    def on_task_finished(self, group_name, message):
        print(message)
        self._mark_group_done(group_name, message)

    def export_data(self):
        if not self.group_game_ids:
            QMessageBox.warning(self, "警告", "没有数据可导出！")
            return

        try:
            # 获取彩金配置
            try:
                bonus_rate = float(self.bonus_rate_input.text())
                bonus_max = float(self.bonus_max_input.text())
                bonus_min = float(self.bonus_min_input.text())
                audit_multiple = float(self.bonus_audit_input.text())
                remark = self.bonus_remark_input.text()
            except ValueError:
                QMessageBox.warning(self, "警告", "彩金配置格式错误，请填写数字！")
                return

            wb = Workbook()
            wb.remove(wb.active)

            # —— 工作表0：整合归总 ——
            ws_all = wb.create_sheet(title="整合归总")
            ws_all['A1'] = 'GameId'
            ws_all['B1'] = 'AppId'
            ws_all['C1'] = 'Source'
            ws_all['D1'] = '有效投注'
            ws_all['F1'] = '游戏总人数'
            ws_all['G1'] = '数据总条数'

            total_unique = sum(len(id_list) for id_list in self.group_game_ids.values())
            total_raw = sum(self.group_raw_counts.get(group, len(id_list))
                            for group, id_list in self.group_game_ids.items())
            total_bet = 0
            for group, bets_dict in self.group_user_bets.items():
                total_bet += sum(bets_dict.values())

            ws_all['F2'] = total_unique
            ws_all['G2'] = total_raw
            ws_all['D2'] = total_bet

            all_row = 4
            ws_all[f'A{all_row - 1}'] = '详细数据列表：'

            for group, id_list in self.group_game_ids.items():
                user_bets = self.group_user_bets.get(group, {})
                app_id_map = self.group_app_id_maps.get(group, {})

                for gid in id_list:
                    ws_all[f"A{all_row}"] = gid
                    ws_all[f"B{all_row}"] = app_id_map.get(gid, '')
                    ws_all[f"C{all_row}"] = group
                    ws_all[f"D{all_row}"] = user_bets.get(gid, 0)
                    all_row += 1

            ws_all.column_dimensions['A'].width = 15
            ws_all.column_dimensions['B'].width = 15
            ws_all.column_dimensions['C'].width = 12
            ws_all.column_dimensions['D'].width = 15
            ws_all.column_dimensions['F'].width = 12
            ws_all.column_dimensions['G'].width = 12

            # —— 彩金发放记录sheet ——
            ws_bonus = wb.create_sheet(title="彩金发放记录")

            ws_bonus['A1'] = '归属'
            ws_bonus['B1'] = '会员ID'
            ws_bonus['C1'] = '奖励金额(必填)'
            ws_bonus['D1'] = '稽核倍数(必填)'
            ws_bonus['E1'] = '前台备注'
            ws_bonus['F1'] = '后台备注'

            ws_bonus.column_dimensions['A'].width = 12
            ws_bonus.column_dimensions['B'].width = 20
            ws_bonus.column_dimensions['C'].width = 15
            ws_bonus.column_dimensions['D'].width = 12
            ws_bonus.column_dimensions['E'].width = 15
            ws_bonus.column_dimensions['F'].width = 15

            bonus_row = 2
            total_bonus_amount = 0
            bonus_count = 0

            for group, id_list in self.group_game_ids.items():
                user_bets = self.group_user_bets.get(group, {})
                app_id_map = self.group_app_id_maps.get(group, {})

                for gid in id_list:
                    bet_amount = user_bets.get(gid, 0)
                    raw_bonus = bet_amount * bonus_rate
                    bonus = round(raw_bonus)

                    if bonus_min <= bonus <= bonus_max:
                        ws_bonus[f'A{bonus_row}'] = group
                        ws_bonus[f'B{bonus_row}'] = app_id_map.get(gid, '')
                        ws_bonus[f'C{bonus_row}'] = bonus
                        ws_bonus[f'D{bonus_row}'] = audit_multiple
                        ws_bonus[f'E{bonus_row}'] = remark
                        ws_bonus[f'F{bonus_row}'] = remark

                        total_bonus_amount += bonus
                        bonus_count += 1
                        bonus_row += 1
                    elif bonus > bonus_max:
                        ws_bonus[f'A{bonus_row}'] = group
                        ws_bonus[f'B{bonus_row}'] = app_id_map.get(gid, '')
                        ws_bonus[f'C{bonus_row}'] = bonus_max
                        ws_bonus[f'D{bonus_row}'] = audit_multiple
                        ws_bonus[f'E{bonus_row}'] = remark
                        ws_bonus[f'F{bonus_row}'] = remark

                        total_bonus_amount += bonus_max
                        bonus_count += 1
                        bonus_row += 1

            ws_bonus[f'A{bonus_row + 1}'] = '统计信息：'
            ws_bonus[f'A{bonus_row + 2}'] = f'发放人数：{bonus_count}'
            ws_bonus[f'A{bonus_row + 3}'] = f'发放总彩金：{total_bonus_amount}元'

            # —— 每个小组一个表 ——
            for group, id_list in self.group_game_ids.items():
                user_bets = self.group_user_bets.get(group, {})
                app_id_map = self.group_app_id_maps.get(group, {})

                ws = wb.create_sheet(title=group[:31])
                ws['A1'] = 'GameId'
                ws['B1'] = 'AppId'
                ws['C1'] = 'Source'
                ws['D1'] = '有效投注'
                ws['F1'] = '游戏总人数'
                ws['G1'] = '数据总条数'

                ws['F2'] = len(id_list)
                ws['G2'] = self.group_raw_counts.get(group, len(id_list))
                ws['D2'] = sum(user_bets.values())

                ws[f'A{3}'] = '详细数据列表：'
                for i, gid in enumerate(id_list, start=4):
                    ws[f"A{i}"] = gid
                    ws[f"B{i}"] = app_id_map.get(gid, '')
                    ws[f"C{i}"] = group
                    ws[f"D{i}"] = user_bets.get(gid, 0)

                ws.column_dimensions['A'].width = 15
                ws.column_dimensions['B'].width = 15
                ws.column_dimensions['C'].width = 12
                ws.column_dimensions['D'].width = 15
                ws.column_dimensions['F'].width = 12
                ws.column_dimensions['G'].width = 12

            rq = datetime.now().strftime('%Y年%m月%d日%H时%M分%S秒')
            file_name = f'多小组游戏数据统计_{rq}.xlsx'
            wb.save(file_name)

            QMessageBox.information(self, "提示",
                                    f"数据已导出到 {file_name}\n彩金发放记录：{bonus_count}人，总计{total_bonus_amount}元")
            os.startfile(file_name)

        except Exception as e:
            QMessageBox.warning(self, "警告", f"导出数据失败: {e}")

    def disable_ui(self):
        self.start_time_input.setEnabled(False)
        self.end_time_input.setEnabled(False)
        self.get_button.setEnabled(False)
        self.export_button.setEnabled(False)
        self.prev_day_btn.setEnabled(False)
        self.today_btn.setEnabled(False)
        self.next_day_btn.setEnabled(False)

        self.save_button.setEnabled(False)
        # 禁用彩金配置
        self.bonus_rate_input.setEnabled(False)
        self.bonus_max_input.setEnabled(False)
        self.bonus_min_input.setEnabled(False)
        self.bonus_audit_input.setEnabled(False)
        self.bonus_remark_input.setEnabled(False)
        # 禁用定时任务
        self.schedule_checkbox.setEnabled(False)
        self.schedule_time_input.setEnabled(False)
        # 禁用所有 Cookie 输入框
        for le in self.token_inputs.values():
            le.setEnabled(False)

    def enable_ui(self):
        self.start_time_input.setEnabled(True)
        self.end_time_input.setEnabled(True)
        self.get_button.setEnabled(True)
        self.export_button.setEnabled(True)
        self.prev_day_btn.setEnabled(True)
        self.today_btn.setEnabled(True)
        self.next_day_btn.setEnabled(True)

        self.save_button.setEnabled(True)
        # 启用彩金配置
        self.bonus_rate_input.setEnabled(True)
        self.bonus_max_input.setEnabled(True)
        self.bonus_min_input.setEnabled(True)
        self.bonus_audit_input.setEnabled(True)
        self.bonus_remark_input.setEnabled(True)
        # 启用定时任务
        self.schedule_checkbox.setEnabled(True)
        self.schedule_time_input.setEnabled(True)
        # 启用所有 Cookie 输入框
        for le in self.token_inputs.values():
            le.setEnabled(True)

    def load_group_names_from_config(self):
        config = ConfigParser()

        # 尝试多种编码读取配置文件
        encodings = ['utf-8', 'gbk', 'gb2312', 'ansi']
        file_read = False

        for encoding in encodings:
            try:
                config.read('config.ini', encoding=encoding)
                file_read = True
                break
            except UnicodeDecodeError:
                continue
            except FileNotFoundError:
                # 文件不存在，返回默认值
                return ["lvcha", "yaoji", "sejie", "aisebo", "xingf", "shaonv", "renqi", "lemi", "cshuang", "zhifu",
                        "fupo"]

        if not file_read:
            # 如果所有编码都失败，尝试以二进制模式读取并忽略错误
            try:
                with open('config.ini', 'r', encoding='utf-8', errors='ignore') as f:
                    config.read_file(f)
            except:
                return ["lvcha", "yaoji", "sejie", "aisebo", "xingf", "shaonv", "renqi", "lemi", "cshuang", "zhifu",
                        "fupo"]

        if 'GROUP_COOKIES' in config:
            return list(config['GROUP_COOKIES'].keys())
        return ["lvcha", "yaoji", "sejie", "aisebo", "xingf", "shaonv", "renqi", "lemi", "cshuang", "zhifu", "fupo"]

    def save_config(self, port, token_dict, code):
        config = ConfigParser()
        config['COMMON'] = {'Port': port, 'Code': code}
        config['GROUP_COOKIES'] = {group: token for group, token in token_dict.items()}

        # 保存彩金配置
        config['BONUS_SETTINGS'] = {
            'rate': self.bonus_rate_input.text(),
            'max_amount': self.bonus_max_input.text(),
            'min_amount': self.bonus_min_input.text(),
            'audit_multiple': self.bonus_audit_input.text(),
            'remark': self.bonus_remark_input.text()
        }

        # 保存定时任务配置
        times = []
        for i in range(self.schedule_list.count()):
            times.append(self.schedule_list.item(i).text())

        config['SCHEDULED_TASKS'] = {
            'enabled': str(self.schedule_checkbox.isChecked()),
            'task_times': ','.join(times)
        }

        # 使用 UTF-8 编码保存
        with open('config.ini', 'w', encoding='utf-8') as configfile:
            config.write(configfile)

        print("配置文件已保存 (UTF-8编码)")

    def load_config(self):
        config = ConfigParser()

        # 尝试多种编码读取配置文件
        encodings = ['utf-8', 'gbk', 'gb2312', 'ansi', 'utf-8-sig']
        file_read = False

        for encoding in encodings:
            try:
                config.read('config.ini', encoding=encoding)
                file_read = True
                print(f"配置文件使用 {encoding} 编码读取成功")
                break
            except UnicodeDecodeError:
                continue
            except FileNotFoundError:
                # 文件不存在，直接返回
                print("配置文件不存在，将使用默认值")
                return

        if not file_read:
            # 如果所有编码都失败，尝试以二进制模式读取并忽略错误
            try:
                with open('config.ini', 'r', encoding='utf-8', errors='ignore') as f:
                    config.read_file(f)
                print("配置文件使用 utf-8 忽略错误模式读取成功")
            except Exception as e:
                print(f"配置文件读取失败: {e}")
                return

        # 加载基础参数
        if 'COMMON' in config:
            self.port_input.setText(config['COMMON'].get('Port', ''))
            self.code_input.setText(config['COMMON'].get('Code', ''))

        # 加载Cookie配置
        if 'GROUP_COOKIES' in config:
            for group in self.groups:
                if group in config['GROUP_COOKIES']:
                    self.token_inputs[group].setText(config['GROUP_COOKIES'][group])

        # 加载彩金配置
        if 'BONUS_SETTINGS' in config:
            self.bonus_rate_input.setText(config['BONUS_SETTINGS'].get('rate', '0.001'))
            self.bonus_max_input.setText(config['BONUS_SETTINGS'].get('max_amount', '8'))
            self.bonus_min_input.setText(config['BONUS_SETTINGS'].get('min_amount', '1'))
            self.bonus_audit_input.setText(config['BONUS_SETTINGS'].get('audit_multiple', '1'))
            self.bonus_remark_input.setText(config['BONUS_SETTINGS'].get('remark', '限时福利'))

        # 加载定时任务配置
        if 'SCHEDULED_TASKS' in config:
            enabled = config['SCHEDULED_TASKS'].get('enabled', 'false') == 'True'
            self.schedule_checkbox.setChecked(enabled)

            times_str = config['SCHEDULED_TASKS'].get('task_times', '')
            if times_str:
                times = times_str.split(',')
                self.schedule_list.clear()
                for time_str in times:
                    if time_str.strip():
                        self.schedule_list.addItem(time_str.strip())

                if enabled:
                    self.start_schedule_timers()

    def manual_save(self):
        port = self.port_input.text()
        code = self.code_input.text()

        token_dict = {}
        missing_groups = []

        for group, input_field in self.token_inputs.items():
            token = input_field.text()
            if token:
                token_dict[group] = token
                input_field.setStyleSheet("")
            else:
                missing_groups.append(group)
                input_field.setStyleSheet("border: 1px solid red;")

        if not port or not code:
            QMessageBox.warning(self, "警告", "请填写完整的配置（port和code）！")
            return

        self.save_config(port, token_dict, code)

        if missing_groups:
            missing_text = "、".join(missing_groups)
            QMessageBox.information(self, "部分保存成功", f"配置已保存，但以下小组未填写 Cookie：{missing_text}")
        else:
            QMessageBox.information(self, "提示", "✅ 配置已完整保存！")


if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = UserWindow()
    window.show()
    sys.exit(app.exec_())
