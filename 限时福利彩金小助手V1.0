        self.end_time_input = QDateTimeEdit()
        self.end_time_input.setCalendarPopup(True)
        self.end_time_input.setDisplayFormat("yyyy-MM-dd HH:mm:ss")

        date_layout.addWidget(QLabel("开始时间："))
        date_layout.addWidget(self.start_time_input)
        date_layout.addWidget(QLabel("结束时间："))
        date_layout.addWidget(self.end_time_input)

        nav_layout = QHBoxLayout()

        self.prev_day_btn = QPushButton("⏪ 上一日")
        self.prev_day_btn.clicked.connect(self.on_prev_day_clicked)
        nav_layout.addWidget(self.prev_day_btn)

        self.today_btn = QPushButton("⏺️ 当日")
        self.today_btn.clicked.connect(self.on_today_clicked)
        nav_layout.addWidget(self.today_btn)

        self.next_day_btn = QPushButton("下一日 ⏩")
        self.next_day_btn.clicked.connect(self.on_next_day_clicked)
        nav_layout.addWidget(self.next_day_btn)

        date_layout.addLayout(nav_layout)
        date_group.setLayout(date_layout)
        layout.addWidget(date_group)

        # 操作按钮水平布局
        button_layout = QHBoxLayout()

        self.get_button = QPushButton("🚀 开始获取")
        self.get_button.clicked.connect(self.start_processing)
        button_layout.addWidget(self.get_button)

        self.export_button = QPushButton("📤 导出数据")
        self.export_button.clicked.connect(self.export_data)
        button_layout.addWidget(self.export_button)

        layout.addSpacing(16)
        layout.addLayout(button_layout)

        self.data_tab.setLayout(layout)

        # 初始样式设置
        self.highlight_selected_button(self.today_btn)

    def highlight_selected_button(self, selected_button):
        buttons = [self.prev_day_btn, self.today_btn, self.next_day_btn]
        for btn in buttons:
            if btn == selected_button:
                btn.setStyleSheet("""
                    QPushButton {
                        background-color: #1DA1F2;
                        color: white;
                        border-radius: 6px;
                        padding: 8px 14px;
                        font-weight: bold;
                    }
                    QPushButton:hover {
                        background-color: #0d8ddf;
                    }
                """)
            else:
                btn.setStyleSheet("""
                    QPushButton {
                        background-color: white;
                        color: #3498db;
                        border: 1px solid #3498db;
                        border-radius: 6px;
                        padding: 8px 14px;
                        font-weight: bold;
                    }
                    QPushButton:hover {
                        background-color: #ecf5fb;
                        color: #2980b9;
                        border: 1px solid #2980b9;
                    }
                """)

    def on_prev_day_clicked(self):
        self.move_to_previous_day()
        self.highlight_selected_button(self.prev_day_btn)

    def on_today_clicked(self):
        self.set_default_dates()
        self.highlight_selected_button(self.today_btn)

    def on_next_day_clicked(self):
        self.move_to_next_day()
        self.highlight_selected_button(self.next_day_btn)

    # ===== 定时任务相关方法 =====
    def add_schedule_time(self):
        """添加定时时间段"""
        time_str = self.schedule_time_input.time().toString("HH:mm")
        # 检查是否已存在
        exists = False
        for i in range(self.schedule_list.count()):
            if self.schedule_list.item(i).text() == time_str:
                exists = True
                break

        if not exists:
            self.schedule_list.addItem(time_str)
            self.save_schedule_config()

    def remove_schedule_time(self):
        """删除选中的定时时间段"""
        current_row = self.schedule_list.currentRow()
        if current_row >= 0:
            self.schedule_list.takeItem(current_row)
            self.save_schedule_config()

    def on_schedule_toggle(self, state):
        """定时任务开关切换"""
        if state == Qt.Checked:
            self.start_schedule_timers()
        else:
            self.stop_schedule_timers()

    def start_schedule_timers(self):
        """启动所有定时器"""
        # 先停止所有现有定时器
        self.stop_schedule_timers()

        # 获取时间段列表
        times = []
        for i in range(self.schedule_list.count()):
            times.append(self.schedule_list.item(i).text())

        if not times:
            self.next_run_label.setText("下次运行：请添加时间段")
            return

        self.schedule_times = times
        self.schedule_timers = []

        # 为每个时间段创建定时器
        for time_str in times:
            self.start_single_timer(time_str)

        self.update_next_run_times()

    def start_single_timer(self, time_str):
        """启动单个定时器"""
        # 解析时间
        hour, minute = map(int, time_str.split(':'))

        # 计算下次运行时间
        now = QDateTime.currentDateTime()
        schedule_time = QDateTime(now.date(), QTime(hour, minute, 0))

        if schedule_time <= now:
            schedule_time = schedule_time.addDays(1)

        # 计算间隔毫秒
        interval = now.msecsTo(schedule_time)

        # 创建定时器
        timer = QTimer()
        timer.setSingleShot(True)
        timer.timeout.connect(lambda: self.on_schedule_trigger(time_str))
        timer.start(interval)

        self.schedule_timers.append(timer)

    def on_schedule_trigger(self, time_str):
        """定时任务触发"""
        print(f"⏰ 定时任务触发 [{time_str}]")
        self.status_label.setText(f"状态：定时任务触发 [{time_str}]")

        # 设置为当日日期
        self.set_default_dates()

        # 执行数据获取
        self.start_processing()

        # 重新启动该时间段的定时器（明天同一时间）
        if self.schedule_checkbox.isChecked():
            self.start_single_timer(time_str)
            self.update_next_run_times()

    def stop_schedule_timers(self):
        """停止所有定时器"""
        for timer in self.schedule_timers:
            timer.stop()
        self.schedule_timers.clear()
        self.next_run_label.setText("下次运行：未启动")

    def update_next_run_times(self):
        """更新下次运行时间显示"""
        if not self.schedule_checkbox.isChecked() or not self.schedule_times:
            self.next_run_label.setText("下次运行：未启动")
            return

        next_times = []
        now = QDateTime.currentDateTime()

        for time_str in self.schedule_times:
            hour, minute = map(int, time_str.split(':'))
            schedule_time = QDateTime(now.date(), QTime(hour, minute, 0))

            if schedule_time <= now:
                schedule_time = schedule_time.addDays(1)

            next_times.append(schedule_time.toString("MM-dd HH:mm"))

        self.next_run_label.setText(f"下次运行：{', '.join(next_times)}")

    def save_schedule_config(self):
        """保存定时设置到配置文件"""
        times = []
        for i in range(self.schedule_list.count()):
            times.append(self.schedule_list.item(i).text())

        # 更新配置
        config = ConfigParser()
        config.read('config.ini')

        if 'SCHEDULED_TASKS' not in config:
            config['SCHEDULED_TASKS'] = {}

        config['SCHEDULED_TASKS']['enabled'] = str(self.schedule_checkbox.isChecked())
        config['SCHEDULED_TASKS']['task_times'] = ','.join(times)

        with open('config.ini', 'w') as configfile:
            config.write(configfile)

        # 如果启用状态，重启定时器
        if self.schedule_checkbox.isChecked():
            self.start_schedule_timers()

        QMessageBox.information(self, "提示", "定时设置已保存")

    def setup_config_tab(self):  # 配置页面
        layout = QVBoxLayout()

        config_group = QGroupBox("分组 Cookie 配置")
        grid = QGridLayout()

        max_rows_per_column = 8
        for i, group in enumerate(self.groups):
            row = i % max_rows_per_column
            col = (i // max_rows_per_column) * 2

            label = QLabel(f"{group}：")
            line_edit = QLineEdit()
            line_edit.setPlaceholderText(f"请输入{group}Cookie")
            self.token_inputs[group] = line_edit

            grid.addWidget(label, row, col)
            grid.addWidget(line_edit, row, col + 1)

        config_group.setLayout(grid)
        layout.addWidget(config_group)

        # 端口配置
